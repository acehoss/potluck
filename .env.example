# SQLite database location. In Docker this points at the /data volume.
DATABASE_URL="file:./data/coop.db"

# Set to 1 to create demo households/users on startup (dev and e2e only).
SEED_DEMO=0

# Root of the image volume (receipt/unit/item photos). /data/images in Docker.
IMAGES_DIR=./data/images

# VLM receipt extraction (blueprint 04 §3). off = manual entry only (the UI
# never offers extraction); fixture = deterministic committed fixtures for
# e2e (no network, no key); live = the Anthropic API.
EXTRACTION_MODE=off
EXTRACTION_MODEL=claude-opus-4-8
# Required only when EXTRACTION_MODE=live. Keep it out of images and git —
# pass it through the environment at runtime.
ANTHROPIC_API_KEY=

# Web push (blueprint 04 §4). Generate a keypair once per deployment:
#   npx web-push generate-vapid-keys
# and paste it here (or export in the host env). Leave empty to disable push.
# docker-compose.yml falls back to a PUBLICLY KNOWN dev/e2e pair when unset —
# never rely on that fallback for a real deployment.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL/mailto the push services may use to reach the operator.
VAPID_SUBJECT=mailto:you@example.com

# --- MFA (Phase 3 Round B; docs/REWORK.md N8/N10) --------------------------
# Base64 32-byte key that encrypts TOTP secrets at rest (AES-256-GCM). REQUIRED
# in production — the instance-admin account must enroll TOTP, so MFA has no
# "disabled" mode. Generate one and keep it out of git:
#   openssl rand -base64 32
# Leave empty for local/demo (SEED_DEMO=1): the entrypoint injects a PUBLICLY
# KNOWN dev key and refuses to boot a non-demo stack that carries it or lacks a
# real key. Rotating this key invalidates every stored TOTP secret (members
# must re-enroll); the emailed-code factor still works as a fallback.
MFA_ENC_KEY=

# --- Mail substrate (Phase 3 Round A; docs/REWORK.md N1–N11) ---------------
# SMTP transport creds. Leave empty to disable live send (mail is then only
# recorded to the CapturedEmail audit table). On DreamHost, 587 is STARTTLS.
EMAIL_FROM=no-reply@potluckmutualaid.app
EMAIL_USERNAME=no-reply@potluckmutualaid.app
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.dreamhost.com
EMAIL_SMTP_PORT=587
# IMAP is used only by the opt-in real-send e2e suite to confirm delivery.
EMAIL_IMAP_SERVER=imap.dreamhost.com
EMAIL_IMAP_PORT=993

# capture = record every message to CapturedEmail, never touch SMTP (default,
# and the only safe mode for a seeded/demo stack). live = also hand approved
# recipients to SMTP.
MAIL_MODE=capture
# Explicit production opt-in. When 1, the dev filter is disabled and mail goes
# to its real recipients untouched. NEVER set on a seeded/demo stack — the
# entrypoint refuses to start with SEED_DEMO=1 + MAIL_MODE=live + this.
MAIL_PRODUCTION=
# Dev filter (ignored when MAIL_PRODUCTION=1). Comma-separated.
#   ALLOWLIST: regexes; a recipient matching any is delivered as-is.
#   REDIRECT:  addresses non-allowlisted mail is redirected to (empty = capture
#              only, nobody gets real mail — fail closed).
#   SUBJECT_PREFIX: prepended to every dev subject.
MAIL_DEV_ALLOWLIST=
MAIL_DEV_REDIRECT=
MAIL_DEV_SUBJECT_PREFIX=[Potluck Dev]
# Base URL used to build the RFC-8058 List-Unsubscribe link in subscription
# mail, and the HMAC secret that signs (and, at /unsub, verifies) its one-click
# token. REQUIRED in production: a stack with MAIL_PRODUCTION=1 refuses to boot
# without its own MAIL_UNSUB_SECRET, because the committed dev fallback is public
# and would make unsubscribe tokens forgeable. Generate one and keep it out of
# git:  openssl rand -base64 32
# Leave empty for local/demo (SEED_DEMO=1): the entrypoint injects the dev value.
MAIL_PUBLIC_URL=https://potluckmutualaid.app
MAIL_UNSUB_SECRET=
