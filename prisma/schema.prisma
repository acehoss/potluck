generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Household {
  id        String   @id @default(cuid())
  name      String
  // URL-safe handle, unique per instance — the future `household@instance`
  // address (REWORK E2). Assigned at creation; raw cuids never leave the
  // instance unqualified.
  slug      String   @unique
  createdAt DateTime @default(now())

  memberships Membership[]
  pantries    Pantry[]
  invites     Invite[]
  purchases   Restock[]    @relation("purchases")
  items       Item[]
  orders      Order[]
  products    Product[]
  connectionsA Connection[] @relation("connectionA")
  connectionsB Connection[] @relation("connectionB")
  sharePosts   SharePost[]
  recipes      Recipe[]
  ingredientLinks IngredientLink[]
}

model User {
  id           String   @id @default(cuid())
  // Login identity (REWORK A2): unique per instance, charset [a-z0-9_-]{3,30}
  // so `user@instance` addressing works at federation time. Email stays
  // required + unique below — recovery, notifications, admin contact — but is
  // no longer the identity.
  username     String   @unique
  name         String
  email        String   @unique
  passwordHash String
  // Instance-admin (REWORK A4): first user of a fresh instance. Controls the
  // new-household-invite toggle and the admin usage view. Instance-scoped, so
  // it lives on User, not Membership.
  isInstanceAdmin Boolean @default(false)
  createdAt    DateTime @default(now())

  memberships       Membership[]
  sessions          Session[]
  invitesCreated    Invite[]
  restocksCreated   Restock[]
  takes             Take[]
  ledgerSeen        LedgerSeen[]
  loans             Loan[]
  pushSubscriptions PushSubscription[]
  ordersCreated     Order[]
}

// ---- Potluck Round 1: network core (REWORK.md) -------------------------------

// User ↔ household with per-membership capability flags (REWORK A3/A3a).
// A user may belong to N households; every authz check in code is a typed
// capability test against the ACTING membership (the sticky acting-household
// context). Named roles (Owner/Adult/Teen/Child) are UI presets over these
// flags, not schema. `placeOrders` is REWORK's `order` flag, renamed: `order`
// is a SQL keyword and collides with the Order model.
model Membership {
  id          String @id @default(cuid())
  userId      String
  householdId String

  manageHousehold   Boolean @default(false) // rename, pantries, memberships/roles, shared flags
  manageConnections Boolean @default(false) // initiate/accept/sever, edit grants
  receiveStock      Boolean @default(false) // run receiving (restocks)
  placeOrders       Boolean @default(false) // build/submit orders, browse/draft cross-household
  spend             Boolean @default(false) // money-moving submissions (cross-household order, fee-bearing checkout)
  fulfill           Boolean @default(false) // pick/ready/hand off incoming orders; confirm share handoffs
  adjustInventory   Boolean @default(false) // recount, write-off
  lendBorrow        Boolean @default(false) // check out/return loans
  postShares        Boolean @default(false) // needs/surpluses posts (Round 2)
  editRecipes       Boolean @default(false) // recipe book, planner, shopping list writes (Rounds 3–4)
  settleMoney       Boolean @default(false) // settlements, manual adjustments, correct-credit, void-in-error

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id])

  @@unique([userId, householdId])
  @@index([householdId])
}

// Pairwise household↔household edge (REWORK B1/B2). Canonically ordered
// (householdAId < householdBId) so the pair is unique. Two DIRECTIONAL grant
// sets: aGrants* is what A permits B to do with A's resources, bGrants* the
// reverse — each side edits only its own set and may tighten/revoke at any
// time without the other's consent ("resource owner is authoritative").
// Lifecycle: PENDING (requested) → ACTIVE (accepted) → SEVERED (unilateral;
// terminal — a new edge is a fresh request).
model Connection {
  id                     String  @id @default(cuid())
  householdAId           String
  householdBId           String
  status                 String  @default("PENDING") // "PENDING" | "ACTIVE" | "SEVERED"
  // Which household initiated (accept authz + display). Null for edges the
  // system created (data migration, new-household invites).
  requestedByHouseholdId String?

  aGrantsPantry    Boolean @default(false) // B may browse A's shared pantries + order against them
  aGrantsLending   Boolean @default(false) // B may browse A's shared items + borrow them
  aGrantsRecipes   Boolean @default(false) // B may browse A's non-private recipes (Round 3)
  aGrantsShareTo   Boolean @default(false) // A's posts reach B (Round 2)
  aGrantsShareFrom Boolean @default(false) // B's posts are shown to A (Round 2)
  aGrantsReshare   Boolean @default(false) // B may reshare A's posts onward (Round 2)
  bGrantsPantry    Boolean @default(false)
  bGrantsLending   Boolean @default(false)
  bGrantsRecipes   Boolean @default(false)
  bGrantsShareTo   Boolean @default(false)
  bGrantsShareFrom Boolean @default(false)
  bGrantsReshare   Boolean @default(false)

  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  severedAt   DateTime?

  householdA Household @relation("connectionA", fields: [householdAId], references: [id])
  householdB Household @relation("connectionB", fields: [householdBId], references: [id])

  @@unique([householdAId, householdBId])
  @@index([householdBId])
}

// Singleton (id = "instance"): operator-level settings (REWORK A1/A4/D2).
model InstanceSettings {
  id        String   @id
  // A1: any member may invite a NEW household (the invite is the first
  // connection edge) unless the instance admin restricts it to admin-only.
  allowMemberHouseholdInvites Boolean @default(true)
  createdAt DateTime @default(now())
}

// ---- slice 7: web push (blueprint 04 §4) ------------------------------------

// One browser push endpoint per row, owned by the user who subscribed in that
// browser. Endpoint is globally unique (a browser re-subscribing after a user
// switch reassigns the row). Rows are pruned server-side when the push service
// answers 404/410 (expired/uninstalled — iOS silently drops subscriptions when
// the PWA icon is deleted).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-pair "last looked at the ledger" watermark (blueprint 01 slice 4): an
// entry between this user's household and the counterparty, created after
// seenAt by someone other than this user, carries the "new" marker. Per-pair
// (not one user-wide stamp) so that with >2 households, viewing one pair
// never swallows another pair's unseen entries. seenAt is the ledger page's
// RENDER timestamp, never mutation-time now() — entries created between the
// render and the markSeen write stay unseen.
model LedgerSeen {
  userId                  String
  // The viewer's OWN side of the pair — under multi-membership a user can
  // watch the same counterparty from two acting households, and viewing the
  // A–C pair must never swallow B–C's unseen entries. Relation-free.
  ownHouseholdId          String
  counterpartyHouseholdId String
  seenAt                  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, ownHouseholdId, counterpartyHouseholdId])
}

model Session {
  // sha256 hex of the session token; the raw token lives only in the cookie
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invite {
  id          String    @id @default(cuid())
  // sha256 hex of the invite token; the raw token lives only in the shared link
  tokenHash   String    @unique
  // "member" joins householdId; "household" (REWORK A1) founds a NEW
  // household whose first connection edge is householdId — growth along
  // trust edges, never open registration.
  kind        String    @default("member")
  householdId String
  createdById String
  invitedName String?
  // Household invites: the initial grant set (GrantSet JSON) both sides start
  // with; each side tunes unilaterally afterwards (B2).
  grantsJson  String?
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdAt   DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

model Pantry {
  id          String   @id @default(cuid())
  householdId String
  name        String
  // Household-wide shared/private flag (REWORK B3): a connection holding the
  // pantry grant sees exactly the shared set, identically for every
  // connection. Private pantries are visible to the owning household only.
  shared      Boolean  @default(true)
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  restocks  Restock[]
  orders    Order[]
}

// ---- slice 2: receiving (blueprint 01) ------------------------------------

model Product {
  id        String   @id @default(cuid())
  // Per-household product namespace (REWORK D1): each household curates its
  // own catalog; cross-household duplicates are by design. A product belongs
  // to the household that OWNS the pantry its lots live in (the purchaser may
  // differ — the pantry owner is the catalog owner). Browsing a connected
  // pantry shows the owner's product names.
  householdId String
  name        String
  // No unique: SKU merging is out of scope; the UI warns on dupes.
  upc         String?
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  lots      Lot[]
  ingredientLinks IngredientLink[]

  @@index([householdId, upc])
  @@index([householdId])
}

model Restock {
  id                   String    @id @default(cuid())
  pantryId             String
  purchaserHouseholdId String
  createdById          String // user who ran the receiving flow
  retailer             String
  purchasedAt          DateTime // receipt date; drives dateCode
  status               String    @default("DRAFT") // "DRAFT" | "FINALIZED"
  dateCode             String? // "260702", set at finalize
  seq                  Int? // NN, 1-based; display code = `${dateCode}-${pad2(seq)}`
  receiptTotalCents    Int?
  // Non-inventory receipt amounts (blueprint 01 D7 — the tax-allocation door is
  // now open). taxCents is split pro-rata across taxable lots at finalize;
  // feesCents is split across ALL lots' pre-tax totals only when feesDistributed
  // (otherwise the purchaser eats it). Both fold into each lot's frozen unitCost,
  // so takes and credits are truly at-cost.
  taxCents             Int?
  feesCents            Int?
  feesDistributed      Boolean   @default(false)
  varianceCents        Int? // receiptTotal − (Σ lineTotal + tax + fees), set at finalize (D7)
  // Set by restock.voidInError: an auditable "entered by mistake" — the active
  // credit is reversed and every lot's remainingCount is zeroed (only allowed
  // while no take references a lot). The row stays FINALIZED for the audit trail.
  voidedAt             DateTime?
  // ---- slice 5: VLM extraction (blueprint 01/04 §3). Advisory only — the
  // raw result is stored for audit/re-extraction; lines materialize solely
  // through user-confirmed saveLine calls. Editable even after finalize
  // (blueprint 01 immutability: "frozen except the slice-5 extraction
  // columns"), though v1 only extracts while DRAFT.
  extractedAt          DateTime?
  extractionModel      String?
  extractionJson       String?
  // JSON array of extractionJson line indices the user has resolved
  // (confirmed into a lot or dismissed). Kept server-side so proposals
  // survive refresh/tab-kill/step-back (blueprint 02) and a resolved line is
  // never re-proposed. Reset whenever a new extraction is stored.
  extractionResolved   String?
  finalizedAt          DateTime?
  createdAt            DateTime  @default(now())

  pantry             Pantry         @relation(fields: [pantryId], references: [id])
  purchaserHousehold Household      @relation("purchases", fields: [purchaserHouseholdId], references: [id])
  createdBy          User           @relation(fields: [createdById], references: [id])
  images             RestockImage[]
  lots               Lot[]

  @@unique([dateCode, seq])
  @@index([pantryId])
}

model RestockImage {
  id        String @id @default(cuid())
  restockId String
  path      String // under IMAGES_DIR volume; retained permanently (SPEC §4)
  position  Int
  // sha256 (hex) of the ORIGINAL selected file, computed client-side before
  // the canvas downscale (which re-encodes browser-dependently). Keys
  // fixture-mode extraction deterministically (blueprint 04 §3); null when
  // the client couldn't hash (non-secure context) — live/off modes ignore it.
  originalSha256 String?

  restock Restock @relation(fields: [restockId], references: [id], onDelete: Cascade)

  @@unique([restockId, position])
}

// ---- slice 3: takes & ledger -----------------------------------------------

// Append-only (blueprint 01 D2): a Take row is immutable; undo sets
// reversedAt and posts a swapped-party REVERSAL ledger entry.
model Take {
  id           String    @id @default(cuid())
  clientKey    String?   @unique // idempotency key: a replayed create returns this take instead of double-taking
  lotId        String
  takerId      String // user who acted (audit); the money-bearing household is householdId
  // The household the units transferred TO — snapshotted at pickup from
  // Order.householdId, never re-derived from the taker user (a user may hold
  // N memberships; live derivation would mis-attribute money). Relation-free
  // like LedgerEntry's household columns.
  householdId  String
  quantity     Int // > 0
  costCents    Int // quantity × lot.unitCostCents; 0 when own-household OR a share gift
  // Round 2 (REWORK C1/F5): set when this take is a GIFT drawn from a confirmed
  // share claim. A share-claim take is $0 and cross-household is allowed with
  // NO LedgerEntry — shares never touch the ledger, unlike an order pickup take
  // (this amends blueprint-01 invariant 4). NOT unique: one confirm can gift
  // from several linked lots → several takes, all carrying the same claim id.
  shareClaimId String?
  takenAt      DateTime  @default(now())
  reversedAt   DateTime?
  reversedById String?

  lot   Lot  @relation(fields: [lotId], references: [id])
  taker User @relation(fields: [takerId], references: [id])

  @@index([lotId])
  @@index([shareClaimId])
}

// Pulled forward from the slice-3 plan: finalize must post the purchaser
// credit (blueprint 01 D1, invariant 5), so the ledger table exists now.
// Takes arrive in slice 3. Intentionally relation-free (blueprint 01).
model LedgerEntry {
  id                  String   @id @default(cuid())
  // Idempotency key for the user-authored money entries (settle/adjust): a
  // replayed mutation returns the original entry instead of double-posting.
  clientKey           String?  @unique
  type                String // "TAKE" | "RESTOCK_CREDIT" | "LOAN_FEE" | "SETTLEMENT" | "WRITE_OFF" | "ADJUSTMENT" | "REVERSAL"
  creditorHouseholdId String // is owed amountCents…
  debtorHouseholdId   String // …by this household. Always creditor ≠ debtor, amount > 0.
  amountCents         Int
  note                String?
  createdById         String
  createdAt           DateTime @default(now())
  takeId              String?  @unique // set for TAKE (slice 3)
  restockId           String? // set for RESTOCK_CREDIT and its correction entries
  loanId              String?  @unique // set for LOAN_FEE (slice 6)
  reversesId          String?  @unique // set for REVERSAL → the entry it cancels

  @@index([creditorHouseholdId, debtorHouseholdId])
  @@index([restockId])
}

model Lot {
  id             String    @id @default(cuid())
  restockId      String
  // Null ONLY for an excluded line (see `excluded`): a receipt line that
  // counts toward the tax/fee distribution weight but never becomes inventory.
  productId      String?
  position       Int // line order on the receipt
  purchasedCount Int // eaches bought (bulk packs pre-broken at entry); 0 for excluded
  receivedCount  Int // eaches into the pantry; 0..purchasedCount (hold-backs = difference)
  lineTotalCents Int // as printed, covers all purchasedCount units
  // Whether this line was taxed — earns a pro-rata share of the receipt tax at
  // finalize, folded into unitCost. Excluded lines can be taxable too (their
  // share is the purchaser's own cost, not credited to anyone).
  taxable        Boolean   @default(false)
  // A non-inventory line: no product, no units into the pantry — present only
  // so the receipt reconciles and fee distribution is accurate. receivedCount
  // and purchasedCount are 0; unitCost stays null.
  excluded       Boolean   @default(false)
  // Raw receipt line text (from extraction), kept for display beside the
  // product on the review card and detail. Null for manually entered lines.
  receiptText    String?
  unitCostCents  Int? // frozen at finalize (D1); null while DRAFT or excluded
  // Tax / fee cents folded into this lot's unitCost at finalize (audit + display
  // of "unit cost incl. tax"); null while DRAFT.
  taxCentsAllocated Int?
  feeCentsAllocated Int?
  remainingCount Int       @default(0) // set to receivedCount at finalize (D3)
  // Units held by open orders (REQUESTED/PICKING/READY). Availability shown and
  // guarded everywhere is remainingCount − reservedCount; a soft hold that never
  // touches the ledger. Bumped on request, released on cancel/edit-down, and
  // decremented (with remainingCount) at pickup.
  reservedCount  Int       @default(0)
  bestBy         DateTime?
  unitPhotoPath  String?

  restock      Restock        @relation(fields: [restockId], references: [id], onDelete: Cascade)
  product      Product?       @relation(fields: [productId], references: [id])
  takes        Take[]
  adjustments  Adjustment[]
  orderLines   OrderLine[]
  sharePostLots SharePostLot[]

  @@unique([restockId, position])
  @@index([productId])
}

// ---- slice 4: adjustments (settlement is a LedgerEntry, blueprint 01 D5) ----

// Recount (set a lot's physical count) or write-off (expired/damaged).
// Amountless by construction: neither touches the ledger in v1 — the owner
// household eats the drift/cost (blueprint 01 invariant 8). Rows immutable.
model Adjustment {
  id          String   @id @default(cuid())
  // Idempotency key: write-offs are cumulative (a double-tap would decrement
  // twice), so a replay returns the original adjustment instead.
  clientKey   String?  @unique
  lotId       String
  type        String // "RECOUNT" | "WRITE_OFF"
  countBefore Int // read by the SERVER inside the tx — never client-supplied
  countAfter  Int // RECOUNT: the physical count (≥ 0); WRITE_OFF: before − writtenOff
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  lot Lot @relation(fields: [lotId], references: [id])

  @@index([lotId])
}

// ---- slice 6: lending (blueprint 01) -----------------------------------------

// Durable equipment owned by a household (SPEC §4). The per-loan fee defaults
// to $0 and exists for maintenance-heavy or partially consumable gear; edits
// affect FUTURE loans only (Loan.feeCents is a snapshot).
model Item {
  id          String   @id @default(cuid())
  // Idempotency key: a photo-less create has no other server-side dedupe, so
  // a double-tap replay must return the original item, not a twin.
  clientKey   String?  @unique
  householdId String
  name        String
  photoPath   String? // under IMAGES_DIR volume, kind "items"
  notes       String?
  feeCents    Int      @default(0)
  // Shared/private flag (REWORK B3), mirroring Pantry.shared: connections with
  // the lending grant see exactly the shared items.
  shared      Boolean  @default(true)
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  loans     Loan[]

  @@index([householdId])
}

// item + borrower + out date + optional due date + returned date + condition
// note (SPEC §4). The fee posts to the ledger AT CHECKOUT (invariant 10: iff
// feeCents > 0 and borrower household ≠ item household); LedgerEntry.loanId
// links the LOAN_FEE entry back. One active loan per item is enforced both in
// the checkout transaction and mechanically by a raw-SQL partial unique index
// (see the slice6_lending migration — Prisma can't express partial indexes).
model Loan {
  id                String    @id @default(cuid())
  // Idempotency key: checkout posts money, so a double-tap/lost-response
  // replay must return the original loan instead of double-charging.
  clientKey         String?   @unique
  itemId            String
  borrowerId        String // user who acted (audit); the borrowing household is borrowerHouseholdId
  // The household that borrowed (and owes any fee) — snapshotted at checkout
  // from the acting household, never re-derived from the borrower user
  // (multi-membership would mis-attribute). Relation-free like LedgerEntry.
  borrowerHouseholdId String
  feeCents          Int // snapshot of item.feeCents at checkout; immutable
  outAt             DateTime  @default(now())
  dueAt             DateTime?
  returnedAt        DateTime?
  conditionReturned String?

  item     Item @relation(fields: [itemId], references: [id])
  borrower User @relation(fields: [borrowerId], references: [id])

  @@index([itemId])
}

// ---- orders: build → request → fulfil → pickup (2026-07 round) --------------

// An order is built by a household against ONE pantry (the "store"). Every
// order runs the same lifecycle — there is no instant-take path:
//   DRAFT      cart being built; nothing reserved
//   REQUESTED  submitted; each line's units reserved on its lot (availability
//              = remainingCount − reservedCount); the requester may still edit
//   PICKING    owner started picking; edits LOCK
//   READY      owner set it aside for pickup
//   PICKED_UP  goods changed hands → a Take + (cross-household) TAKE ledger
//              entry post per line, exactly here (money posts at pickup only)
//   CANCELED   from DRAFT/REQUESTED only; releases reservations; ledger untouched
// Money posts solely at pickup, so that transition carries a clientKey and runs
// through dbTransaction (money rule #2); the ledger stays append-only (a
// post-pickup return is take.undo's swapped-party REVERSAL, never an edit).
model Order {
  id          String    @id @default(cuid())
  // Idempotency for the money-posting pickup; a replayed pickup returns the
  // original result instead of double-posting the takes/credits.
  clientKey   String?   @unique
  pantryId    String
  householdId String // requester household (the pantry's owner household is the "store")
  createdById String
  status      String    @default("DRAFT") // DRAFT | REQUESTED | PICKING | READY | PICKED_UP | CANCELED
  note        String?
  requestedAt DateTime?
  pickingAt   DateTime?
  readyAt     DateTime?
  pickedUpAt  DateTime?
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())

  pantry    Pantry      @relation(fields: [pantryId], references: [id])
  household Household   @relation(fields: [householdId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])
  lines     OrderLine[]

  @@index([householdId])
  @@index([pantryId])
}

// One lot-specific line in an order (the requester picks the lot, FIFO default,
// so cost freezes trivially at that lot's unitCost). takeId is set at pickup to
// the Take row that recorded the transfer (audit link; the ledger is separate).
model OrderLine {
  id       String  @id @default(cuid())
  orderId  String
  lotId    String
  quantity Int // > 0 while the line exists (0 removes it)
  takeId   String? @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot   Lot   @relation(fields: [lotId], references: [id])

  @@index([orderId])
  @@index([lotId])
}

// ---- Round 2: needs & surpluses (REWORK F) ----------------------------------

// A post is a NEED or a SURPLUS. Shares are GIFTS (C1): they never touch the
// ledger — a tracked SURPLUS handoff records $0 Takes for the audit trail only.
// ValueFlows correspondence (E3, names only): a post ≈ Intent/Proposal, a claim
// ≈ Commitment, the gift take ≈ EconomicEvent.
model SharePost {
  id            String    @id @default(cuid())
  clientKey     String?   @unique
  type          String    // "NEED" | "SURPLUS"
  householdId   String    // the POSTING household (acting) — for a reshare copy, the RESHARER
  createdById   String
  title         String
  description   String?
  photoPath     String?   // IMAGES_DIR kind "shares"
  // Optional quantity (F1): null = whole-thing/unspecified. unit is free text.
  quantity      Int?
  unit          String?
  // Remaining tracks down as claims CONFIRM. Stored ONLY on origin posts;
  // reshare copies resolve it from the origin at read time (single source of
  // truth — "origin's remaining mirrors down", F4).
  remaining     Int?
  expiresAt     DateTime  // required (F1); defaults: SURPLUS +3d, NEED +14d
  status        String    @default("OPEN") // OPEN | CLAIMED | FULFILLED | WITHDRAWN (expiry is derived, never stored)
  // Reshare chain (E3/F4): origin + hops from day one.
  originPostId  String?   // root post id; null = this IS the origin
  parentPostId  String?   // the post this copy reshared; null = origin
  hopsRemaining Int       @default(1) // poster-set allowance 0..3; copies get parent-1
  createdAt     DateTime  @default(now())

  household Household      @relation(fields: [householdId], references: [id])
  lots      SharePostLot[]
  claims    ShareClaim[]

  @@index([householdId])
  @@index([originPostId])
  @@index([parentPostId])
}

// Provenance link: which tracked lots a SURPLUS origin offers (own-household,
// FINALIZED, non-excluded lots). The $0 transfer draws from these on confirm.
model SharePostLot {
  id     String @id @default(cuid())
  postId String
  lotId  String

  post SharePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  lot  Lot       @relation(fields: [lotId], references: [id])

  @@unique([postId, lotId])
}

model ShareClaim {
  id          String    @id @default(cuid())
  clientKey   String?   @unique
  postId      String
  householdId String    // the CLAIMING household (acting) — snapshot, never re-derived
  createdById String
  quantity    Int?      // required iff the post carries a quantity
  note        String?
  status      String    @default("PENDING") // PENDING | CONFIRMED | RELEASED | CANCELED
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  post SharePost @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([householdId])
}

// ---- Round 3: recipes (REWORK G) --------------------------------------------

// PTE-shaped: structured ingredient lines + section headings; only title is
// required (G1). Recipes belong to a household; cross-household browsing rides
// the `recipes` grant over an ACTIVE edge plus the per-recipe private flag
// (G3). Saving a foreign recipe FORKS it — browse-live, fork-on-save; author
// edits never propagate to copies. NO money, NO ledger anywhere in this model.
model Recipe {
  id          String   @id @default(cuid())
  clientKey   String?  @unique
  householdId String
  createdById String
  title       String   // the ONLY required field (G1)
  description String?
  directions  String?  // free text, newline-separated steps
  prepMinutes Int?
  cookMinutes Int?
  servings    Int?     // proportional-scaling basis (scaling is display-time)
  yieldText   String?  // separate from servings ("2 loaves"), PTE-shaped
  course      String?  // free-vocabulary strings (user-editable lists are UI)
  cuisine     String?
  tags        String?  // comma-separated, trimmed; UI splits/joins
  photoPath   String?  // IMAGES_DIR kind "recipes"
  private     Boolean  @default(false) // G3: default = visible to recipe-granted connections
  sourceUrl   String?  // URL-import provenance
  // Fork attribution (G3): SNAPSHOTS, deliberately not FKs — the source may be
  // deleted/unshared/severed later and the copy stands alone.
  forkedFromTitle         String?
  forkedFromHouseholdName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household   Household          @relation(fields: [householdId], references: [id])
  ingredients RecipeIngredient[]

  @@index([householdId])
}

model RecipeIngredient {
  id       String  @id @default(cuid())
  recipeId String
  position Int
  kind     String  @default("item") // "item" | "heading" (section headings, G1)
  amount   String? // RAW TEXT ("1 1/2", "2-3") — never parsed server-side; scaling is a display concern
  unit     String?
  text     String  // ingredient name for kind=item; the heading text for kind=heading
  note     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, position])
}

// G2: the LEARNED per-household ingredient-name → product mapping. Written only
// on explicit user confirmation (never silently), resolved at read time for
// EVERY recipe (own/forked/browsed). Quantities NEVER convert across the link —
// the UI shows recipe amounts and pantry counts side by side.
model IngredientLink {
  id             String @id @default(cuid())
  householdId    String
  normalizedName String // lower-cased, whitespace-collapsed ingredient text
  productId      String

  household Household @relation(fields: [householdId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([householdId, normalizedName])
}
