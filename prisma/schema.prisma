generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members   User[]
  pantries  Pantry[]
  invites   Invite[]
  purchases Restock[] @relation("purchases")
}

model User {
  id           String   @id @default(cuid())
  householdId  String
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  household       Household    @relation(fields: [householdId], references: [id])
  sessions        Session[]
  invitesCreated  Invite[]
  restocksCreated Restock[]
  takes           Take[]
  ledgerSeen      LedgerSeen[]
}

// Per-pair "last looked at the ledger" watermark (blueprint 01 slice 4): an
// entry between this user's household and the counterparty, created after
// seenAt by someone other than this user, carries the "new" marker. Per-pair
// (not one user-wide stamp) so that with >2 households, viewing one pair
// never swallows another pair's unseen entries. seenAt is the ledger page's
// RENDER timestamp, never mutation-time now() — entries created between the
// render and the markSeen write stay unseen.
model LedgerSeen {
  userId                  String
  counterpartyHouseholdId String
  seenAt                  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, counterpartyHouseholdId])
}

model Session {
  // sha256 hex of the session token; the raw token lives only in the cookie
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invite {
  id          String    @id @default(cuid())
  // sha256 hex of the invite token; the raw token lives only in the shared link
  tokenHash   String    @unique
  householdId String
  createdById String
  invitedName String?
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdAt   DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

model Pantry {
  id          String   @id @default(cuid())
  householdId String
  name        String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  restocks  Restock[]
}

// ---- slice 2: receiving (blueprint 01) ------------------------------------

model Product {
  id        String   @id @default(cuid())
  name      String
  // No unique: SKU merging is out of scope; the UI warns on dupes.
  upc       String?
  createdAt DateTime @default(now())

  lots Lot[]

  @@index([upc])
}

model Restock {
  id                   String    @id @default(cuid())
  pantryId             String
  purchaserHouseholdId String
  createdById          String // user who ran the receiving flow
  retailer             String
  purchasedAt          DateTime // receipt date; drives dateCode
  status               String    @default("DRAFT") // "DRAFT" | "FINALIZED"
  dateCode             String? // "260702", set at finalize
  seq                  Int? // NN, 1-based; display code = `${dateCode}-${pad2(seq)}`
  receiptTotalCents    Int?
  varianceCents        Int? // receiptTotal − Σ lineTotal, set at finalize (D7)
  // ---- slice 5: VLM extraction (blueprint 01/04 §3). Advisory only — the
  // raw result is stored for audit/re-extraction; lines materialize solely
  // through user-confirmed saveLine calls. Editable even after finalize
  // (blueprint 01 immutability: "frozen except the slice-5 extraction
  // columns"), though v1 only extracts while DRAFT.
  extractedAt          DateTime?
  extractionModel      String?
  extractionJson       String?
  // JSON array of extractionJson line indices the user has resolved
  // (confirmed into a lot or dismissed). Kept server-side so proposals
  // survive refresh/tab-kill/step-back (blueprint 02) and a resolved line is
  // never re-proposed. Reset whenever a new extraction is stored.
  extractionResolved   String?
  finalizedAt          DateTime?
  createdAt            DateTime  @default(now())

  pantry             Pantry         @relation(fields: [pantryId], references: [id])
  purchaserHousehold Household      @relation("purchases", fields: [purchaserHouseholdId], references: [id])
  createdBy          User           @relation(fields: [createdById], references: [id])
  images             RestockImage[]
  lots               Lot[]

  @@unique([dateCode, seq])
  @@index([pantryId])
}

model RestockImage {
  id        String @id @default(cuid())
  restockId String
  path      String // under IMAGES_DIR volume; retained permanently (SPEC §4)
  position  Int
  // sha256 (hex) of the ORIGINAL selected file, computed client-side before
  // the canvas downscale (which re-encodes browser-dependently). Keys
  // fixture-mode extraction deterministically (blueprint 04 §3); null when
  // the client couldn't hash (non-secure context) — live/off modes ignore it.
  originalSha256 String?

  restock Restock @relation(fields: [restockId], references: [id], onDelete: Cascade)

  @@unique([restockId, position])
}

// ---- slice 3: takes & ledger -----------------------------------------------

// Append-only (blueprint 01 D2): a Take row is immutable; undo sets
// reversedAt and posts a swapped-party REVERSAL ledger entry.
model Take {
  id           String    @id @default(cuid())
  clientKey    String?   @unique // idempotency key: a replayed create returns this take instead of double-taking
  lotId        String
  takerId      String // user; household derived via taker
  quantity     Int // > 0
  costCents    Int // quantity × lot.unitCostCents; 0 when own-household
  takenAt      DateTime  @default(now())
  reversedAt   DateTime?
  reversedById String?

  lot   Lot  @relation(fields: [lotId], references: [id])
  taker User @relation(fields: [takerId], references: [id])

  @@index([lotId])
}

// Pulled forward from the slice-3 plan: finalize must post the purchaser
// credit (blueprint 01 D1, invariant 5), so the ledger table exists now.
// Takes arrive in slice 3. Intentionally relation-free (blueprint 01).
model LedgerEntry {
  id                  String   @id @default(cuid())
  // Idempotency key for the user-authored money entries (settle/adjust): a
  // replayed mutation returns the original entry instead of double-posting.
  clientKey           String?  @unique
  type                String // "TAKE" | "RESTOCK_CREDIT" | "LOAN_FEE" | "SETTLEMENT" | "WRITE_OFF" | "ADJUSTMENT" | "REVERSAL"
  creditorHouseholdId String // is owed amountCents…
  debtorHouseholdId   String // …by this household. Always creditor ≠ debtor, amount > 0.
  amountCents         Int
  note                String?
  createdById         String
  createdAt           DateTime @default(now())
  takeId              String?  @unique // set for TAKE (slice 3)
  restockId           String? // set for RESTOCK_CREDIT and its correction entries
  loanId              String?  @unique // set for LOAN_FEE (slice 6)
  reversesId          String?  @unique // set for REVERSAL → the entry it cancels

  @@index([creditorHouseholdId, debtorHouseholdId])
  @@index([restockId])
}

model Lot {
  id             String    @id @default(cuid())
  restockId      String
  productId      String
  position       Int // line order on the receipt
  purchasedCount Int // eaches bought (bulk packs pre-broken at entry)
  receivedCount  Int // eaches into the pantry; 0..purchasedCount (hold-backs = difference)
  lineTotalCents Int // as printed, covers all purchasedCount units
  unitCostCents  Int? // frozen at finalize (D1); null while DRAFT
  remainingCount Int       @default(0) // set to receivedCount at finalize (D3)
  bestBy         DateTime?
  unitPhotoPath  String?

  restock     Restock      @relation(fields: [restockId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  takes       Take[]
  adjustments Adjustment[]

  @@unique([restockId, position])
  @@index([productId])
}

// ---- slice 4: adjustments (settlement is a LedgerEntry, blueprint 01 D5) ----

// Recount (set a lot's physical count) or write-off (expired/damaged).
// Amountless by construction: neither touches the ledger in v1 — the owner
// household eats the drift/cost (blueprint 01 invariant 8). Rows immutable.
model Adjustment {
  id          String   @id @default(cuid())
  // Idempotency key: write-offs are cumulative (a double-tap would decrement
  // twice), so a replay returns the original adjustment instead.
  clientKey   String?  @unique
  lotId       String
  type        String // "RECOUNT" | "WRITE_OFF"
  countBefore Int // read by the SERVER inside the tx — never client-supplied
  countAfter  Int // RECOUNT: the physical count (≥ 0); WRITE_OFF: before − writtenOff
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  lot Lot @relation(fields: [lotId], references: [id])

  @@index([lotId])
}
