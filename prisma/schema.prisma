generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Household {
  id        String   @id @default(cuid())
  name      String
  // URL-safe handle, unique per instance — the future `household@instance`
  // address (REWORK E2). Assigned at creation; raw cuids never leave the
  // instance unqualified.
  slug      String   @unique
  // Contact layer (REWORK P5, Round C): the household's pickup logistics,
  // shown on a connected household's card. address is a free-text (multiline)
  // location; pickupNotes is the focus-group's top-ranked field ("side door,
  // text when 5 min out"). Visible to any ACTIVE-connected household — the
  // connection itself is the gate (P5).
  address     String?
  pickupNotes String?
  createdAt DateTime @default(now())

  memberships Membership[]
  pantries    Pantry[]
  invites     Invite[]
  purchases   Restock[]    @relation("purchases")
  items       Item[]
  orders      Order[]
  products    Product[]
  connectionsA Connection[] @relation("connectionA")
  connectionsB Connection[] @relation("connectionB")
  circles      Circle[]
  sharePosts   SharePost[]
  recipes      Recipe[]
  ingredientLinks IngredientLink[]
  planEntries         PlanEntry[]
  shoppingItems       ShoppingItem[]
  categoryAssignments CategoryAssignment[]
}

model User {
  id           String   @id @default(cuid())
  // Login identity (REWORK A2): unique per instance, charset [a-z0-9_-]{3,30}
  // so `user@instance` addressing works at federation time. Email stays
  // required + unique below — recovery, notifications, admin contact — but is
  // no longer the identity.
  username     String   @unique
  name         String
  email        String   @unique
  passwordHash String
  // Instance-admin (REWORK A4): first user of a fresh instance. Controls the
  // new-household-invite toggle and the admin usage view. Instance-scoped, so
  // it lives on User, not Membership.
  isInstanceAdmin Boolean @default(false)
  // Contact layer (REWORK P5, Round C): the person's card. photoPath is an
  // "avatars"-kind image; phone is free text (UI renders tel:/sms:); bio is a
  // short blurb. All optional — visibility on a household card is governed by
  // Membership.visibility + circles, never by presence.
  photoPath    String?
  phone        String?
  bio          String?
  // Account security (Phase 3 Round B; docs/REWORK.md N8/N10). emailVerifiedAt
  // is set when the emailed verification link is consumed (null = unverified;
  // this round only banners it, never blocks login). totpSecret is the AES-256-
  // GCM-encrypted TOTP secret (null = not enrolled); totpEnabledAt is set only
  // after a live code confirms enrollment (a stored-but-not-enabled secret is a
  // begun-but-unconfirmed enrollment). totpLastStep is the highest TOTP time-
  // step already consumed at a login challenge — a code from that step or
  // earlier is replay-rejected. mfaEmailEnabled opts the account into emailed
  // 6-digit codes as a (convenience) second factor.
  emailVerifiedAt DateTime?
  totpSecret      String?
  totpEnabledAt   DateTime?
  totpLastStep    Int?
  mfaEmailEnabled Boolean   @default(false)
  // Notification prefs (Phase 3 Round C; docs/REWORK.md N4/N5/N6 + the digest-
  // cadence round). timezone is an IANA zone (null → instance default/UTC)
  // driving the digest send window; digestCadence ('off'|'daily'|'weekly',
  // default DAILY — timely beats batched for perishable shares) is how often
  // the digest goes out; digestHour (0–23) is the
  // local send hour; digestWeekday (0=Sun..6=Sat) is the local send day used
  // only for the weekly cadence. showDetails (default off) opts this user into
  // seeing the counterparty household NAME in a notification body (still never
  // dollars/addresses — N4); lastDigestAt is the per-user digest idempotency
  // watermark; notifyOnboardedAt marks the first-run "how should Potluck reach
  // you?" consent as seen. Per-CATEGORY channel choices live in
  // NotificationPreference (absent row = the default matrix), NOT here.
  timezone          String?
  digestCadence     String    @default("daily")
  digestHour        Int       @default(9)
  digestWeekday     Int       @default(0)
  showDetails       Boolean   @default(false)
  lastDigestAt      DateTime?
  notifyOnboardedAt DateTime?
  createdAt    DateTime @default(now())

  memberships       Membership[]
  sessions          Session[]
  invitesCreated    Invite[]
  restocksCreated   Restock[]
  takes             Take[]
  transfersCreated  Transfer[]
  ledgerSeen        LedgerSeen[]
  loans             Loan[]
  pushSubscriptions PushSubscription[]
  ordersCreated     Order[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  mfaBackupCodes          MfaBackupCode[]
  emailMfaCodes           EmailMfaCode[]
  notificationPreferences NotificationPreference[]
}

// Per-(user, category) notification channel choice (Phase 3 Round C; N5). One
// row per category the user has TUNED — an ABSENT row means the conservative
// category default (pickups push+email ON; circle OFF/OFF; ledger OFF/OFF), so
// a fresh account carries zero rows and still behaves correctly. category ∈
// "pickups" | "circle" | "ledger" (the three opt-out buckets; "account"/
// transactional mail is never stored here and never unsubscribable). The
// digest + showDetails + timezone are single-valued and live on User instead.
model NotificationPreference {
  userId   String
  category String
  push     Boolean
  email    Boolean

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, category])
}

// ---- Potluck Round 1: network core (REWORK.md) -------------------------------

// User ↔ household with per-membership capability flags (REWORK A3/A3a).
// A user may belong to N households; every authz check in code is a typed
// capability test against the ACTING membership (the sticky acting-household
// context). Named roles (Owner/Adult/Teen/Child) are UI presets over these
// flags, not schema. `placeOrders` is REWORK's `order` flag, renamed: `order`
// is a SQL keyword and collides with the Order model.
model Membership {
  id          String @id @default(cuid())
  userId      String
  householdId String

  manageHousehold   Boolean @default(false) // rename, pantries, memberships/roles, shared flags
  manageConnections Boolean @default(false) // initiate/accept/sever, edit grants
  receiveStock      Boolean @default(false) // run receiving (restocks)
  placeOrders       Boolean @default(false) // build/submit orders, browse/draft cross-household
  spend             Boolean @default(false) // money-moving submissions (cross-household order, fee-bearing checkout)
  fulfill           Boolean @default(false) // pick/ready/hand off incoming orders; confirm share handoffs
  adjustInventory   Boolean @default(false) // recount, write-off
  lendBorrow        Boolean @default(false) // check out/return loans
  postShares        Boolean @default(false) // needs/surpluses posts (Round 2)
  editRecipes       Boolean @default(false) // recipe book, planner, shopping list writes (Rounds 3–4)
  settleMoney       Boolean @default(false) // settlements, manual adjustments, correct-credit, void-in-error

  // Contact-layer visibility (REWORK P4/P5) — which connections see this member
  // on a household card. "ALL" (every circle) | "SELECT" | "PRIVATE"; SELECT
  // consults MembershipCircle. Schema + reach helper land here in Round B; the
  // management UI is Round C's.
  visibility String @default("ALL")

  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id])
  circleScopes MembershipCircle[]

  @@unique([userId, householdId])
  @@index([householdId])
}

// Pairwise household↔household edge (REWORK B1/B2, Phase-2 P4 circles).
// Canonically ordered (householdAId < householdBId) so the pair is unique.
// Grants no longer live on the edge: each side assigns the OTHER household into
// one of ITS OWN circles (a named grant bundle), and that circle's six flags
// ARE the directional grant set. aCircleId = the circle household A placed B
// into (A's outgoing grants toward B); bCircleId the mirror. Directionality is
// preserved; either side re-assigns unilaterally, without the other's consent
// ("resource owner is authoritative"). PENDING sets the requester's side at
// request and the addressee's at accept; ACTIVE ⇒ BOTH non-null (enforced in
// the accept handler, not the schema — the nullability carries PENDING).
// Lifecycle: PENDING (requested) → ACTIVE (accepted) → SEVERED (unilateral;
// terminal — a new edge is a fresh request).
model Connection {
  id                     String  @id @default(cuid())
  householdAId           String
  householdBId           String
  status                 String  @default("PENDING") // "PENDING" | "ACTIVE" | "SEVERED"
  // Which household initiated (accept authz + display). Null for edges the
  // system created (data migration, new-household invites).
  requestedByHouseholdId String?

  // Circle A placed B into (A's grants toward B) / circle B placed A into.
  aCircleId String?
  bCircleId String?

  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  severedAt   DateTime?

  householdA Household @relation("connectionA", fields: [householdAId], references: [id])
  householdB Household @relation("connectionB", fields: [householdBId], references: [id])
  aCircle    Circle?   @relation("connectionACircle", fields: [aCircleId], references: [id])
  bCircle    Circle?   @relation("connectionBCircle", fields: [bCircleId], references: [id])

  @@unique([householdAId, householdBId])
  @@index([householdBId])
  @@index([aCircleId])
  @@index([bCircleId])
}

// Phase 2 (REWORK P4): a household's named visibility/grant group. A circle IS
// a grant bundle — the six directional grants that used to live per-connection.
// Each side of a connection assigns the OTHER side into one of ITS OWN circles
// (directionality preserved); resource scoping (pantry/item/member) targets
// circles. Seeded per household: Neighbors / Friends / Family.
model Circle {
  id          String  @id @default(cuid())
  householdId String
  name        String
  position    Int     @default(0) // display order

  grantsPantry    Boolean @default(false)
  grantsLending   Boolean @default(false)
  grantsRecipes   Boolean @default(false)
  grantsShareTo   Boolean @default(false)
  grantsShareFrom Boolean @default(false)
  grantsReshare   Boolean @default(false)

  createdAt DateTime @default(now())

  household        Household          @relation(fields: [householdId], references: [id])
  connectionsAsA   Connection[]       @relation("connectionACircle")
  connectionsAsB   Connection[]       @relation("connectionBCircle")
  pantryScopes     PantryCircle[]
  itemScopes       ItemCircle[]
  sharePostScopes  SharePostCircle[]
  membershipScopes MembershipCircle[]

  @@unique([householdId, name])
  @@index([householdId])
}

// SELECT-visibility scope rows (REWORK P4). A row means "this pantry is visible
// to this circle"; consulted ONLY when the pantry's visibility is 'SELECT'
// (ALL/PRIVATE ignore them). Circle and pantry always belong to the SAME
// household — a household scopes its own resources to its own circles.
model PantryCircle {
  pantryId String
  circleId String

  pantry Pantry @relation(fields: [pantryId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([pantryId, circleId])
  @@index([circleId])
}

model ItemCircle {
  itemId   String
  circleId String

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([itemId, circleId])
  @@index([circleId])
}

model MembershipCircle {
  membershipId String
  circleId     String

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  circle     Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([membershipId, circleId])
  @@index([circleId])
}

// Singleton (id = "instance"): operator-level settings (REWORK A1/A4/D2).
model InstanceSettings {
  id        String   @id
  // A1: any member may invite a NEW household (the invite is the first
  // connection edge) unless the instance admin restricts it to admin-only.
  allowMemberHouseholdInvites Boolean @default(true)
  createdAt DateTime @default(now())
}

// ---- slice 7: web push (blueprint 04 §4) ------------------------------------

// One browser push endpoint per row, owned by the user who subscribed in that
// browser. Endpoint is globally unique (a browser re-subscribing after a user
// switch reassigns the row). Rows are pruned server-side when the push service
// answers 404/410 (expired/uninstalled — iOS silently drops subscriptions when
// the PWA icon is deleted).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-pair "last looked at the ledger" watermark (blueprint 01 slice 4): an
// entry between this user's household and the counterparty, created after
// seenAt by someone other than this user, carries the "new" marker. Per-pair
// (not one user-wide stamp) so that with >2 households, viewing one pair
// never swallows another pair's unseen entries. seenAt is the ledger page's
// RENDER timestamp, never mutation-time now() — entries created between the
// render and the markSeen write stay unseen.
model LedgerSeen {
  userId                  String
  // The viewer's OWN side of the pair — under multi-membership a user can
  // watch the same counterparty from two acting households, and viewing the
  // A–C pair must never swallow B–C's unseen entries. Relation-free.
  ownHouseholdId          String
  counterpartyHouseholdId String
  seenAt                  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, ownHouseholdId, counterpartyHouseholdId])
}

// Audit of every message either mail pipeline TRIED to send (Phase 3 Round A;
// docs/REWORK.md N1–N11). A row is written whether or not SMTP was actually
// touched: on a capture-mode stack it is the only record, and the dev/e2e
// flows read it back. `toAddress` is the ACTUAL recipient after the dev-filter
// (redirect applied); `originalTo` is the intended recipient before redirect;
// `delivered` is true only when a real SMTP send also happened (MAIL_MODE=live
// past the fail-closed filter).
model CapturedEmail {
  id          String   @id @default(cuid())
  pipeline    String // "transactional" | "subscription"
  kind        String // "verify" | "reset" | "mfa" | "digest" | "share" | "test" | ...
  toAddress   String // the ACTUAL recipient after dev-filter (redirect applied)
  originalTo  String // the intended recipient before redirect
  fromAddress String
  subject     String
  textBody    String
  htmlBody    String?
  headersJson String // JSON of extra headers (List-Unsubscribe etc.)
  delivered   Boolean  @default(false) // true if a real SMTP send also happened
  createdAt   DateTime @default(now())

  @@index([originalTo])
  @@index([createdAt])
}

// Hard-suppression list for SUBSCRIPTION mail only (bounces, spam complaints,
// one-click unsubscribes). Round A: the table exists; nothing populates it yet
// (isSuppressed is therefore always false). Round C wires population + honors
// the /unsub route. Transactional mail never consults this.
model MailSuppression {
  email     String   @id
  reason    String // "bounce" | "complaint" | "unsubscribe" | ...
  createdAt DateTime @default(now())
}

model Session {
  // sha256 hex of the session token; the raw token lives only in the cookie
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---- Phase 3 Round B: account-security tokens + MFA (docs/REWORK.md N8/N10) --

// Emailed email-verification link (enumeration-safe). Only the sha256 hash of
// the raw token is stored — the raw value lives solely in the emailed link, so
// a DB read never yields a usable token. Single-use (usedAt) + short-TTL
// (expiresAt); cascade with the user.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Emailed password-reset link. Same shape/discipline as the verification token
// (hashed-at-rest, single-use, short-TTL). Consuming it revokes the user's
// sessions; if the account has TOTP enrolled the reset ALSO requires a live
// TOTP/backup code in the same call (a reset is not a TOTP bypass — N8).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// One-time MFA recovery code (8–10 per enrolled user). Hashed with the password
// hasher (argon2id) — the raw codes are shown once at enrollment and never
// again. Single-use: verifying consumes the matching row (usedAt).
model MfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// The emailed 6-digit MFA code (convenience second factor + enrollment proof).
// Hashed at rest; short-TTL (expiresAt); attempt-capped (attempts → the code
// dies) and single-use. At most one live row per user — issuing a fresh code
// deletes the prior one.
model EmailMfaCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invite {
  id          String    @id @default(cuid())
  // sha256 hex of the invite token; the raw token lives only in the shared link
  tokenHash   String    @unique
  // "member" joins householdId; "household" (REWORK A1) founds a NEW
  // household whose first connection edge is householdId — growth along
  // trust edges, never open registration.
  kind        String    @default("member")
  householdId String
  createdById String
  invitedName String?
  // Household invites: the initial grant set (GrantSet JSON) both sides start
  // with; each side tunes unilaterally afterwards (B2).
  grantsJson  String?
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdAt   DateTime  @default(now())

  household Household @relation(fields: [householdId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])
}

model Pantry {
  id          String   @id @default(cuid())
  householdId String
  name        String
  // Circle-scoped visibility (REWORK P4, replaces B3's shared flag): "ALL"
  // (visible to every circle that holds the pantry grant) | "SELECT" (only the
  // circles joined via PantryCircle) | "PRIVATE" (owning household only). A
  // connection still needs its circle's `grantsPantry` on top of visibility.
  visibility  String   @default("ALL")
  createdAt   DateTime @default(now())

  household Household      @relation(fields: [householdId], references: [id])
  restocks  Restock[]
  orders    Order[]
  circles   PantryCircle[]
  stocks    Stock[]
  transfersOut   Transfer[]      @relation("transfersOut")
  transfersIn    Transfer[]      @relation("transfersIn")
  lotAllocations LotAllocation[]
}

// ---- slice 2: receiving (blueprint 01) ------------------------------------

model Product {
  id        String   @id @default(cuid())
  // Per-household product namespace (REWORK D1): each household curates its
  // own catalog; cross-household duplicates are by design. A product belongs
  // to the household that OWNS the pantry its lots live in (the purchaser may
  // differ — the pantry owner is the catalog owner). Browsing a connected
  // pantry shows the owner's product names.
  householdId String
  name        String
  // No unique: SKU merging is out of scope; the UI warns on dupes.
  upc         String?
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  lots      Lot[]
  ingredientLinks IngredientLink[]
  images    ProductImage[]

  @@index([householdId, upc])
  @@index([householdId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  path      String   // under IMAGES_DIR volume, kind "products"; position 0 is the main photo
  label     String?  // DORMANT: preset-label UI shipped in the media round, dropped 2026-07-07 (not useful in practice); column kept (always null now) so a re-add needs no migration
  position  Int
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, position])
  @@index([productId])
}

model Restock {
  id                   String    @id @default(cuid())
  pantryId             String
  purchaserHouseholdId String
  createdById          String // user who ran the receiving flow
  retailer             String
  purchasedAt          DateTime // receipt date; drives dateCode
  status               String    @default("DRAFT") // "DRAFT" | "FINALIZED"
  dateCode             String? // "260702", set at finalize
  seq                  Int? // NN, 1-based; display code = `${dateCode}-${pad2(seq)}`
  receiptTotalCents    Int?
  // Non-inventory receipt amounts (blueprint 01 D7 — the tax-allocation door is
  // now open). taxCents is split pro-rata across taxable lots at finalize;
  // feesCents is split across ALL lots' pre-tax totals only when feesDistributed
  // (otherwise the purchaser eats it). Both fold into each lot's frozen unitCost,
  // so takes and credits are truly at-cost.
  taxCents             Int?
  feesCents            Int?
  feesDistributed      Boolean   @default(false)
  varianceCents        Int? // receiptTotal − (Σ lineTotal + tax + fees), set at finalize (D7)
  // Set by restock.voidInError: an auditable "entered by mistake" — the active
  // credit is reversed and every lot's remainingCount is zeroed (only allowed
  // while no take references a lot). The row stays FINALIZED for the audit trail.
  voidedAt             DateTime?
  // ---- slice 5: VLM extraction (blueprint 01/04 §3). Advisory only — the
  // raw result is stored for audit/re-extraction; lines materialize solely
  // through user-confirmed saveLine calls. Editable even after finalize
  // (blueprint 01 immutability: "frozen except the slice-5 extraction
  // columns"), though v1 only extracts while DRAFT.
  extractedAt          DateTime?
  extractionModel      String?
  extractionJson       String?
  // JSON array of extractionJson line indices the user has resolved
  // (confirmed into a lot or dismissed). Kept server-side so proposals
  // survive refresh/tab-kill/step-back (blueprint 02) and a resolved line is
  // never re-proposed. Reset whenever a new extraction is stored.
  extractionResolved   String?
  finalizedAt          DateTime?
  createdAt            DateTime  @default(now())

  pantry             Pantry         @relation(fields: [pantryId], references: [id])
  purchaserHousehold Household      @relation("purchases", fields: [purchaserHouseholdId], references: [id])
  createdBy          User           @relation(fields: [createdById], references: [id])
  images             RestockImage[]
  lots               Lot[]

  @@unique([dateCode, seq])
  @@index([pantryId])
}

model RestockImage {
  id        String @id @default(cuid())
  restockId String
  path      String // under IMAGES_DIR volume; retained permanently (SPEC §4)
  position  Int
  // sha256 (hex) of the ORIGINAL selected file, computed client-side before
  // the canvas downscale (which re-encodes browser-dependently). Keys
  // fixture-mode extraction deterministically (blueprint 04 §3); null when
  // the client couldn't hash (non-secure context) — live/off modes ignore it.
  originalSha256 String?

  restock Restock @relation(fields: [restockId], references: [id], onDelete: Cascade)

  @@unique([restockId, position])
}

// ---- slice 3: takes & ledger -----------------------------------------------

// Append-only (blueprint 01 D2): a Take row is immutable; undo sets
// reversedAt and posts a swapped-party REVERSAL ledger entry.
model Take {
  id           String    @id @default(cuid())
  clientKey    String?   @unique // idempotency key: a replayed create returns this take instead of double-taking
  lotId        String
  takerId      String // user who acted (audit); the money-bearing household is householdId
  // The household the units transferred TO — snapshotted at pickup from
  // Order.householdId, never re-derived from the taker user (a user may hold
  // N memberships; live derivation would mis-attribute money). Relation-free
  // like LedgerEntry's household columns.
  householdId  String
  quantity     Int // > 0
  costCents    Int // quantity × lot.unitCostCents; 0 when own-household OR a share gift
  // Round 2 (REWORK C1/F5): set when this take is a GIFT drawn from a confirmed
  // share claim. A share-claim take is $0 and cross-household is allowed with
  // NO LedgerEntry — shares never touch the ledger, unlike an order pickup take
  // (this amends blueprint-01 invariant 4). NOT unique: one confirm can gift
  // from several linked lots → several takes, all carrying the same claim id.
  shareClaimId String?
  // Phase 4 (S2): which pantry the units left — snapshotted at take time from
  // the Stock row drawn down (relation-free like householdId; a placement's
  // future moves must not rewrite where a historical take happened).
  pantryId     String
  takenAt      DateTime  @default(now())
  reversedAt   DateTime?
  reversedById String?

  lot   Lot  @relation(fields: [lotId], references: [id])
  taker User @relation(fields: [takerId], references: [id])

  @@index([lotId])
  @@index([shareClaimId])
}

// Pulled forward from the slice-3 plan: finalize must post the purchaser
// credit (blueprint 01 D1, invariant 5), so the ledger table exists now.
// Takes arrive in slice 3. Intentionally relation-free (blueprint 01).
model LedgerEntry {
  id                  String   @id @default(cuid())
  // Idempotency key for the user-authored money entries (settle/adjust): a
  // replayed mutation returns the original entry instead of double-posting.
  clientKey           String?  @unique
  type                String // "TAKE" | "RESTOCK_CREDIT" | "LOAN_FEE" | "SETTLEMENT" | "WRITE_OFF" | "ADJUSTMENT" | "REVERSAL"
  creditorHouseholdId String // is owed amountCents…
  debtorHouseholdId   String // …by this household. Always creditor ≠ debtor, amount > 0.
  amountCents         Int
  note                String?
  createdById         String
  createdAt           DateTime @default(now())
  takeId              String?  @unique // set for TAKE (slice 3)
  restockId           String? // set for RESTOCK_CREDIT and its correction entries
  loanId              String?  @unique // set for LOAN_FEE (slice 6)
  reversesId          String?  @unique // set for REVERSAL → the entry it cancels

  @@index([creditorHouseholdId, debtorHouseholdId])
  @@index([restockId])
}

model Lot {
  id             String    @id @default(cuid())
  restockId      String
  // Null ONLY for an excluded line (see `excluded`): a receipt line that
  // counts toward the tax/fee distribution weight but never becomes inventory.
  productId      String?
  position       Int // line order on the receipt
  purchasedCount Int // eaches bought (bulk packs pre-broken at entry); 0 for excluded
  receivedCount  Int // eaches into the pantry; 0..purchasedCount (hold-backs = difference)
  lineTotalCents Int // as printed, covers all purchasedCount units
  // Whether this line was taxed — earns a pro-rata share of the receipt tax at
  // finalize, folded into unitCost. Excluded lines can be taxable too (their
  // share is the purchaser's own cost, not credited to anyone).
  taxable        Boolean   @default(false)
  // A non-inventory line: no product, no units into the pantry — present only
  // so the receipt reconciles and fee distribution is accurate. receivedCount
  // and purchasedCount are 0; unitCost stays null.
  excluded       Boolean   @default(false)
  // Raw receipt line text (from extraction), kept for display beside the
  // product on the review card and detail. Null for manually entered lines.
  receiptText    String?
  unitCostCents  Int? // frozen at finalize (D1); null while DRAFT or excluded
  // Tax / fee cents folded into this lot's unitCost at finalize (audit + display
  // of "unit cost incl. tax"); null while DRAFT.
  taxCentsAllocated Int?
  feeCentsAllocated Int?
  bestBy         DateTime?
  unitPhotoPath  String?

  restock      Restock        @relation(fields: [restockId], references: [id], onDelete: Cascade)
  product      Product?       @relation(fields: [productId], references: [id])
  takes        Take[]
  adjustments  Adjustment[]
  orderLines   OrderLine[]
  sharePostLots SharePostLot[]
  stocks       Stock[]
  transferLines TransferLine[]
  allocations   LotAllocation[]

  @@unique([restockId, position])
  @@index([productId])
}

// ---- Phase 4 (REWORK S1/A-series): stock placements --------------------------

// Where a lot's units are NOW. A Lot is the receive event (receipt lineage,
// frozen cost, bestBy, photo); a Stock row is the units of that lot currently
// sitting in one pantry. Finalize materializes one row per non-excluded lot in
// the restock's pantry; transfers and per-line receive splits (Round 2) fan a
// lot across pantries. Rows are durable once created — count may reach 0 but
// the row stays, because OrderLine/Adjustment/SharePostLot history points here.
// count/reservedCount move ONLY through src/server/stock.ts (the choke point).
// Availability shown and guarded everywhere is count − reservedCount;
// reservedCount is the soft order hold that used to live on Lot (bumped on
// request, released on cancel/edit-down, decremented with count at pickup —
// never the ledger). Money stays on Lot: unitCostCents prices takes wherever
// the units sit.
model Stock {
  id            String   @id @default(cuid())
  lotId         String
  pantryId      String
  count         Int      @default(0)
  reservedCount Int      @default(0)
  createdAt     DateTime @default(now())

  lot    Lot    @relation(fields: [lotId], references: [id])
  pantry Pantry @relation(fields: [pantryId], references: [id])

  orderLines    OrderLine[]
  adjustments   Adjustment[]
  sharePostLots SharePostLot[]
  transferLinesFrom TransferLine[] @relation("fromStock")
  transferLinesTo   TransferLine[] @relation("toStock")

  @@unique([lotId, pantryId])
  @@index([pantryId])
  @@index([lotId])
}

// ---- Phase 4 Round 2 (REWORK S3): pantry-to-pantry transfer -------------------

// One physical A→B move of stock between two pantries of the SAME household —
// the one sanctioned way units change pantry outside receive. Immutable once
// created (a mistake is corrected by transferring back); never money, never a
// reservation (movable quantity = count − reservedCount, guarded in
// stock.moveStock). Round 3's reconcile commit will write derived transfers
// through this same table, marked as inferred.
model Transfer {
  id           String   @id @default(cuid())
  // Idempotency key: a replayed create returns the original transfer instead
  // of moving the units twice.
  clientKey    String?  @unique
  householdId  String // owner of BOTH pantries, snapshotted (relation-free like ledger)
  fromPantryId String
  toPantryId   String
  note         String?
  createdById  String
  createdAt    DateTime @default(now())

  fromPantry Pantry @relation("transfersOut", fields: [fromPantryId], references: [id])
  toPantry   Pantry @relation("transfersIn", fields: [toPantryId], references: [id])
  createdBy  User   @relation(fields: [createdById], references: [id])
  lines      TransferLine[]

  @@index([householdId, createdAt])
  @@index([fromPantryId])
  @@index([toPantryId])
}

model TransferLine {
  id          String @id @default(cuid())
  transferId  String
  lotId       String
  fromStockId String
  toStockId   String
  quantity    Int // > 0

  transfer  Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  lot       Lot      @relation(fields: [lotId], references: [id])
  fromStock Stock    @relation("fromStock", fields: [fromStockId], references: [id])
  toStock   Stock    @relation("toStock", fields: [toStockId], references: [id])

  @@index([transferId])
  @@index([lotId])
}

// ---- Phase 4 Round 2 (REWORK S4): per-line receive destinations ---------------

// DRAFT-time allocation of a receipt line across pantries ("6 basement /
// 4 kitchen"). No rows = the whole line lands in the restock's pantry at
// finalize (the overwhelmingly common case). When rows exist for a lot they
// must sum to its receivedCount at finalize, which materializes one placement
// per allocation and then deletes the rows (they are draft-state only — the
// placements ARE the durable answer).
model LotAllocation {
  id       String @id @default(cuid())
  lotId    String
  pantryId String
  count    Int // > 0

  lot    Lot    @relation(fields: [lotId], references: [id], onDelete: Cascade)
  pantry Pantry @relation(fields: [pantryId], references: [id])

  @@unique([lotId, pantryId])
  @@index([pantryId])
}

// ---- slice 4: adjustments (settlement is a LedgerEntry, blueprint 01 D5) ----

// Recount (set a lot's physical count) or write-off (expired/damaged).
// Amountless by construction: neither touches the ledger in v1 — the owner
// household eats the drift/cost (blueprint 01 invariant 8). Rows immutable.
model Adjustment {
  id          String   @id @default(cuid())
  // Idempotency key: write-offs are cumulative (a double-tap would decrement
  // twice), so a replay returns the original adjustment instead.
  clientKey   String?  @unique
  lotId       String
  // Phase 4 (S2): the placement this adjustment recounted/wrote off — counts
  // are per (lot, pantry) now. lotId stays for product/cost lineage.
  stockId     String
  type        String // "RECOUNT" | "WRITE_OFF"
  countBefore Int // read by the SERVER inside the tx — never client-supplied
  countAfter  Int // RECOUNT: the physical count (≥ 0); WRITE_OFF: before − writtenOff
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  lot   Lot   @relation(fields: [lotId], references: [id])
  stock Stock @relation(fields: [stockId], references: [id])

  @@index([lotId])
  @@index([stockId])
}

// ---- slice 6: lending (blueprint 01) -----------------------------------------

// Durable equipment owned by a household (SPEC §4). The per-loan fee defaults
// to $0 and exists for maintenance-heavy or partially consumable gear; edits
// affect FUTURE loans only (Loan.feeCents is a snapshot).
model Item {
  id          String   @id @default(cuid())
  // Idempotency key: a media-less create has no other server-side dedupe, so
  // a double-tap replay must return the original item, not a twin.
  clientKey   String?  @unique
  householdId String
  name        String
  notes       String?
  feeCents    Int      @default(0)
  // Circle-scoped visibility (REWORK P4, replaces B3's shared flag), mirroring
  // Pantry.visibility: "ALL" | "SELECT" (ItemCircle) | "PRIVATE". Items are
  // household-level — no pantry-style inherit. A connection needs its circle's
  // `grantsLending` on top.
  visibility  String   @default("ALL")
  createdAt   DateTime @default(now())

  household Household    @relation(fields: [householdId], references: [id])
  loans     Loan[]
  circles   ItemCircle[]
  images    ItemImage[]
  attachments ItemAttachment[]

  @@index([householdId])
}

model ItemImage {
  id        String   @id @default(cuid())
  itemId    String
  path      String   // under IMAGES_DIR volume, kind "items"; position 0 is the main photo
  label     String?  // DORMANT: preset-label UI shipped in the media round, dropped 2026-07-07 (not useful in practice); column kept (always null now) so a re-add needs no migration
  position  Int
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, position])
  @@index([itemId])
}

model ItemAttachment {
  id        String   @id @default(cuid())
  itemId    String
  path      String   // under IMAGES_DIR volume, kind "attachments"; server-named PDF
  name      String   // sanitized display/download filename
  sizeBytes Int
  position  Int
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, position])
  @@index([itemId])
}

// item + borrower + out date + optional due date + returned date + condition
// note (SPEC §4). The fee posts to the ledger AT CHECKOUT (invariant 10: iff
// feeCents > 0 and borrower household ≠ item household); LedgerEntry.loanId
// links the LOAN_FEE entry back. One active loan per item is enforced both in
// the checkout transaction and mechanically by a raw-SQL partial unique index
// (see the slice6_lending migration — Prisma can't express partial indexes).
model Loan {
  id                String    @id @default(cuid())
  // Idempotency key: checkout posts money, so a double-tap/lost-response
  // replay must return the original loan instead of double-charging.
  clientKey         String?   @unique
  itemId            String
  borrowerId        String // user who acted (audit); the borrowing household is borrowerHouseholdId
  // The household that borrowed (and owes any fee) — snapshotted at checkout
  // from the acting household, never re-derived from the borrower user
  // (multi-membership would mis-attribute). Relation-free like LedgerEntry.
  borrowerHouseholdId String
  feeCents          Int // snapshot of item.feeCents at checkout; immutable
  outAt             DateTime  @default(now())
  dueAt             DateTime?
  returnedAt        DateTime?
  conditionReturned String?

  item     Item @relation(fields: [itemId], references: [id])
  borrower User @relation(fields: [borrowerId], references: [id])

  @@index([itemId])
}

// ---- orders: build → request → fulfil → pickup (2026-07 round) --------------

// An order is built by a household against ONE pantry (the "store"). Every
// order runs the same lifecycle — there is no instant-take path:
//   DRAFT      cart being built; nothing reserved
//   REQUESTED  submitted; each line's units reserved on its lot (availability
//              = remainingCount − reservedCount); the requester may still edit
//   PICKING    owner started picking; edits LOCK
//   READY      owner set it aside for pickup
//   PICKED_UP  goods changed hands → a Take + (cross-household) TAKE ledger
//              entry post per line, exactly here (money posts at pickup only)
//   CANCELED   from DRAFT/REQUESTED only; releases reservations; ledger untouched
// Money posts solely at pickup, so that transition carries a clientKey and runs
// through dbTransaction (money rule #2); the ledger stays append-only (a
// post-pickup return is take.undo's swapped-party REVERSAL, never an edit).
model Order {
  id          String    @id @default(cuid())
  // Idempotency for the money-posting pickup; a replayed pickup returns the
  // original result instead of double-posting the takes/credits.
  clientKey   String?   @unique
  pantryId    String
  householdId String // requester household (the pantry's owner household is the "store")
  createdById String
  status      String    @default("DRAFT") // DRAFT | REQUESTED | PICKING | READY | PICKED_UP | CANCELED
  note        String?
  requestedAt DateTime?
  pickingAt   DateTime?
  readyAt     DateTime?
  pickedUpAt  DateTime?
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())

  pantry    Pantry      @relation(fields: [pantryId], references: [id])
  household Household   @relation(fields: [householdId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])
  lines     OrderLine[]

  @@index([householdId])
  @@index([pantryId])
}

// One lot-specific line in an order (the requester picks the lot, FIFO default,
// so cost freezes trivially at that lot's unitCost). takeId is set at pickup to
// the Take row that recorded the transfer (audit link; the ledger is separate).
model OrderLine {
  id       String  @id @default(cuid())
  orderId  String
  lotId    String
  // Phase 4 (S2): the placement this line draws from — always a Stock row of
  // this line's lot in the order's pantry. The reservation lives there.
  stockId  String
  quantity Int // > 0 while the line exists (0 removes it)
  takeId   String? @unique

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot   Lot   @relation(fields: [lotId], references: [id])
  stock Stock @relation(fields: [stockId], references: [id])

  @@index([orderId])
  @@index([lotId])
  @@index([stockId])
}

// ---- Round 2: needs & surpluses (REWORK F) ----------------------------------

// A post is a NEED or a SURPLUS. Shares are GIFTS (C1): they never touch the
// ledger — a tracked SURPLUS handoff records $0 Takes for the audit trail only.
// ValueFlows correspondence (E3, names only): a post ≈ Intent/Proposal, a claim
// ≈ Commitment, the gift take ≈ EconomicEvent.
model SharePost {
  id            String    @id @default(cuid())
  clientKey     String?   @unique
  type          String    // "NEED" | "SURPLUS"
  householdId   String    // the POSTING household (acting) — for a reshare copy, the RESHARER
  createdById   String
  title         String
  description   String?
  photoPath     String?   // IMAGES_DIR kind "shares"
  // Share visibility (REWORK P4 circle-scoped visibility model): "ALL" reaches
  // every share-visible connection; "SELECT" additionally requires a
  // SharePostCircle match against the poster-side circle.
  visibility    String    @default("ALL")
  // Optional quantity (F1): null = whole-thing/unspecified. unit is free text.
  quantity      Int?
  unit          String?
  // Remaining tracks down as claims CONFIRM. Stored ONLY on origin posts;
  // reshare copies resolve it from the origin at read time (single source of
  // truth — "origin's remaining mirrors down", F4).
  remaining     Int?
  expiresAt     DateTime  // required (F1); defaults: SURPLUS +3d, NEED +14d
  status        String    @default("OPEN") // OPEN | CLAIMED | FULFILLED | WITHDRAWN (expiry is derived, never stored)
  // Reshare chain (E3/F4): origin + hops from day one.
  originPostId  String?   // root post id; null = this IS the origin
  parentPostId  String?   // the post this copy reshared; null = origin
  hopsRemaining Int       @default(1) // poster-set allowance 0..3; copies get parent-1
  createdAt     DateTime  @default(now())

  household Household      @relation(fields: [householdId], references: [id])
  lots      SharePostLot[]
  claims    ShareClaim[]
  circles   SharePostCircle[]

  @@index([householdId])
  @@index([originPostId])
  @@index([parentPostId])
}

model SharePostCircle {
  id          String @id @default(cuid())
  sharePostId String
  circleId    String

  post   SharePost @relation(fields: [sharePostId], references: [id], onDelete: Cascade)
  circle Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([sharePostId, circleId])
  @@index([circleId])
}

// Provenance link: which tracked lots a SURPLUS origin offers (own-household,
// FINALIZED, non-excluded lots). The $0 transfer draws from these on confirm.
model SharePostLot {
  id      String @id @default(cuid())
  postId  String
  lotId   String
  // Phase 4 (S2): the placement the gift draws from — once a lot can sit in
  // several pantries, "which shelf is offered" must be explicit, and the
  // uniqueness is per placement (two shelves of one lot = two links).
  stockId String

  post  SharePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  lot   Lot       @relation(fields: [lotId], references: [id])
  stock Stock     @relation(fields: [stockId], references: [id])

  @@unique([postId, stockId])
  @@index([lotId])
  @@index([stockId])
}

model ShareClaim {
  id          String    @id @default(cuid())
  clientKey   String?   @unique
  postId      String
  householdId String    // the CLAIMING household (acting) — snapshot, never re-derived
  createdById String
  quantity    Int?      // required iff the post carries a quantity
  note        String?
  status      String    @default("PENDING") // PENDING | CONFIRMED | RELEASED | CANCELED
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  post SharePost @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([householdId])
}

// ---- Round 3: recipes (REWORK G) --------------------------------------------

// PTE-shaped: structured ingredient lines + section headings; only title is
// required (G1). Recipes belong to a household; cross-household browsing rides
// the `recipes` grant over an ACTIVE edge plus the per-recipe private flag
// (G3). Saving a foreign recipe FORKS it — browse-live, fork-on-save; author
// edits never propagate to copies. NO money, NO ledger anywhere in this model.
model Recipe {
  id          String   @id @default(cuid())
  clientKey   String?  @unique
  householdId String
  createdById String
  title       String   // the ONLY required field (G1)
  description String?
  directions  String?  // free text, newline-separated steps
  prepMinutes Int?
  cookMinutes Int?
  servings    Int?     // proportional-scaling basis (scaling is display-time)
  yieldText   String?  // separate from servings ("2 loaves"), PTE-shaped
  course      String?  // free-vocabulary strings (user-editable lists are UI)
  cuisine     String?
  tags        String?  // comma-separated, trimmed; UI splits/joins
  photoPath   String?  // IMAGES_DIR kind "recipes"
  private     Boolean  @default(false) // G3: default = visible to recipe-granted connections
  sourceUrl   String?  // URL-import provenance
  // Fork attribution (G3): SNAPSHOTS, deliberately not FKs — the source may be
  // deleted/unshared/severed later and the copy stands alone.
  forkedFromTitle         String?
  forkedFromHouseholdName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household   Household          @relation(fields: [householdId], references: [id])
  ingredients RecipeIngredient[]
  planEntries PlanEntry[]

  @@index([householdId])
}

model RecipeIngredient {
  id       String  @id @default(cuid())
  recipeId String
  position Int
  kind     String  @default("item") // "item" | "heading" (section headings, G1)
  amount   String? // RAW TEXT ("1 1/2", "2-3") — never parsed server-side; scaling is a display concern
  unit     String?
  text     String  // ingredient name for kind=item; the heading text for kind=heading
  note     String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, position])
}

// G2: the LEARNED per-household ingredient-name → product mapping. Written only
// on explicit user confirmation (never silently), resolved at read time for
// EVERY recipe (own/forked/browsed). Quantities NEVER convert across the link —
// the UI shows recipe amounts and pantry counts side by side.
model IngredientLink {
  id             String @id @default(cuid())
  householdId    String
  normalizedName String // lower-cased, whitespace-collapsed ingredient text
  productId      String

  household Household @relation(fields: [householdId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([householdId, normalizedName])
}

// ---- Round 4: meal planner + shopping (REWORK H) ----------------------------

// The planner belongs to a household; editRecipes gates writes (A3a: "recipe
// book, planner, shopping list writes"); reads are any-member. No money here —
// the shopping list's add-to-order hands a suggested lot to the EXISTING order
// flow (order.addToCart), never posting money itself. Scope cuts (J3):
// menus / queue / leftovers / freezer are OUT; a plannable is a recipe, a bare
// ingredient/product line, or a note.
model PlanEntry {
  id               String   @id @default(cuid())
  clientKey        String?  @unique
  householdId      String
  createdById      String
  date             String   // "YYYY-MM-DD" — a local calendar day, no times
  meal             String   @default("dinner") // breakfast|lunch|dinner|snack (zod vocab)
  position         Int      // order within (household, date, meal)
  kind             String   // "recipe" | "item" | "note"
  recipeId         String?  // kind=recipe: the household's OWN book (forks included —
                            // foreign recipes are forked first, fork-on-save)
  servingsOverride Int?     // per-instance scaling (kind=recipe), 1..999
  text             String?  // kind=item: ingredient/product text; kind=note: the note
  // Round S: stamped whenever this entry's ingredients were sent to the shopping
  // list (range shopping.generate or single shopping.addFromEntry). Null = never
  // sent. A deliberate "was sent" marker, NOT a live link — list items merge,
  // get checked, and clear independently (Walt-simple semantics).
  addedToShoppingAt DateTime?
  createdAt        DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id])
  // SetNull (not Cascade): deleting a recipe must not delete its plan entries;
  // the entry survives as a tombstone (week() renders a null-recipeId
  // kind=recipe entry as "(deleted recipe)") so a planned day never silently
  // loses a slot.
  recipe    Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([householdId, date])
}

// One persistent shopping list per household. Rows are NEVER silently removed
// (H2, PTE's pantry lesson): generation UPSERTS, only explicit user actions
// delete. unit is ''-normalized (not null) so the merge key is a real unique.
model ShoppingItem {
  id             String   @id @default(cuid())
  clientKey      String?  @unique
  householdId    String
  title          String   // display text (original casing)
  normalizedName String   // normalizeIngredientName(title) — merge/category/G2 key
  unit           String   @default("") // merge partition: NO cross-unit math (H2)
  amounts        String?  // merged summary: numeric same-unit amounts sum ("3 cups"),
                          // unparseable ones join (" + a splash")
  category       String?  // resolved from CategoryAssignment at write; editable
  checked        Boolean  @default(false)
  manual         Boolean  @default(false)
  sourceNote     String?  // provenance: "Lasagna ×2 · Tacos" — which entries fed it
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, normalizedName, unit])
  @@index([householdId])
}

// Learned per-household category memory (same pattern as IngredientLink):
// written only by the explicit setCategory action, applied at generation.
model CategoryAssignment {
  id             String @id @default(cuid())
  householdId    String
  normalizedName String
  category       String

  household Household @relation(fields: [householdId], references: [id])

  @@unique([householdId, normalizedName])
}
